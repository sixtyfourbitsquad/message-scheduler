# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Comma-separated Telegram user IDs allowed to use the private control panel
ADMIN_TELEGRAM_IDS=123456789

# --- Webhook (required) ---
# Public HTTPS URL without trailing slash, e.g. https://yourname.duckdns.org
WEBHOOK_BASE_URL=https://yourname.duckdns.org
WEBHOOK_PATH=/webhook
# Must match Telegram setWebhook secret_token (alphanumeric, 1-256 chars)
WEBHOOK_SECRET_TOKEN=change_me_to_a_long_random_string

# --- PostgreSQL (required) ---
DATABASE_URL=postgresql+asyncpg://botuser:strongpassword@127.0.0.1:5432/channel_bot

# --- Optional: DuckDNS dynamic DNS updater (cron or startup script) ---
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=

# --- Optional ---
# IANA timezone for default schedule display / scheduler (can be changed in Settings UI)
DEFAULT_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
